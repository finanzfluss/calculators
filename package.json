{
  "name": "@finanzfluss/calculators",
  "type": "module",
  "version": "1.3.0",
  "packageManager": "pnpm@10.30.3",
  "description": "Financial calculators for Finanzfluss",
  "author": "Finflow GmbH",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/finanzfluss/calculators#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finanzfluss/calculators.git"
  },
  "bugs": {
    "url": "https://github.com/finanzfluss/calculators/issues"
  },
  "keywords": [
    "calculator",
    "finanzfluss",
    "finflow"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "default": "./dist/utils/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{css,html,json,js,md,ts,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,js,md,ts,yml}\" --check",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:types": "tsc --noEmit",
    "release": "bumpp"
  },
  "peerDependencies": {
    "@formulajs/formulajs": "^4.5.3",
    "bignumber.js": "^9.3.1",
    "dinero.js": "^2.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@vitest/coverage-v8": "4.0.1",
    "@vitest/ui": "4.0.1",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "ufo": "^1.6.3",
    "vitest": "^4.0.18"
  }
}
